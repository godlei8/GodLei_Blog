<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.godlei.blogserver.mapper.BlogMomentMapper">

    <sql id="momentColumns">
        id,
        content,
        location,
        publish_time AS publishTime,
        status,
        created_at AS createdAt,
        updated_at AS updatedAt
    </sql>

    <select id="listAdmin" resultType="cn.godlei.blogpojo.entity.BlogMoment">
        SELECT
        <include refid="momentColumns"/>
        FROM blog_moment
        <where>
            <if test="status != null">
                status = #{status}
            </if>
        </where>
        ORDER BY publish_time DESC, id DESC
    </select>

    <select id="listPublic" resultType="cn.godlei.blogpojo.entity.BlogMoment">
        SELECT
        <include refid="momentColumns"/>
        FROM blog_moment
        WHERE status = #{status}
          AND publish_time <![CDATA[ <= ]]> NOW()
        ORDER BY publish_time DESC, id DESC
    </select>

    <select id="getById" resultType="cn.godlei.blogpojo.entity.BlogMoment">
        SELECT
        <include refid="momentColumns"/>
        FROM blog_moment
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="cn.godlei.blogpojo.entity.BlogMoment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO blog_moment (
            content,
            location,
            publish_time,
            status
        )
        VALUES (
            #{content},
            #{location},
            #{publishTime},
            #{status}
        )
    </insert>

    <update id="update" parameterType="cn.godlei.blogpojo.entity.BlogMoment">
        UPDATE blog_moment
        SET
            content = #{content},
            location = #{location},
            publish_time = #{publishTime},
            status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM blog_moment
        WHERE id = #{id}
    </delete>
</mapper>
