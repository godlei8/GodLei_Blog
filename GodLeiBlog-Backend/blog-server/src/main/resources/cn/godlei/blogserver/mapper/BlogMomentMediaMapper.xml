<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.godlei.blogserver.mapper.BlogMomentMediaMapper">

    <select id="listByMomentIds" resultType="cn.godlei.blogpojo.entity.BlogMomentMedia">
        SELECT
            id,
            moment_id AS momentId,
            media_url AS mediaUrl,
            sort
        FROM blog_moment_media
        WHERE moment_id IN
        <foreach collection="momentIds" item="momentId" open="(" close=")" separator=",">
            #{momentId}
        </foreach>
        ORDER BY moment_id ASC, sort ASC, id ASC
    </select>

    <delete id="deleteByMomentId">
        DELETE FROM blog_moment_media
        WHERE moment_id = #{momentId}
    </delete>

    <insert id="batchInsert">
        INSERT INTO blog_moment_media (
            moment_id,
            media_url,
            sort
        )
        VALUES
        <foreach collection="mediaList" item="item" separator=",">
            (
                #{item.momentId},
                #{item.mediaUrl},
                #{item.sort}
            )
        </foreach>
    </insert>
</mapper>
