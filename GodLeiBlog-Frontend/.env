# Frontend API always goes through the same-origin /api prefix.
VITE_API_BASE_URL=/api

# Local dev proxy target for the Spring backend.
VITE_API_PROXY_TARGET=http://localhost:8080

# Twikoo comments use the same-origin proxy in all environments.
VITE_TWIKOO_URL=/twikoo-proxy/

# Local dev and preview should point at the local Twikoo process by default.
VITE_TWIKOO_PROXY_TARGET=http://localhost:3000

# Override locally when you need to debug another Twikoo instance.
# VITE_TWIKOO_PROXY_TARGET=https://your-twikoo-host/twikoo/
