# Copy this file to /opt/godleiblog/backend/backend.env and edit the values.

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

HM_DB_HOST=127.0.0.1
HM_DB_PASSWORD=replace-with-your-mysql-password
HM_LOCAL_DB_USERNAME=root
HM_LOCAL_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/godleiblog?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true

BLOG_STORAGE_MODE=local
HM_LOCAL_UPLOAD_DIR=/opt/godleiblog/data/uploads
BLOG_STORAGE_PUBLIC_PATH=/uploads
BLOG_STORAGE_PUBLIC_BASE_URL=

JAVA_OPTS=-Xms256m -Xmx512m -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai
