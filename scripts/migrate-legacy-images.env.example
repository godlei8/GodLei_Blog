# Copy this file and adjust it for your target environment.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=godleiblog
DB_USER=root
DB_PASSWORD=

UPLOAD_BASE_DIR=/opt/godleiblog/data/uploads
UPLOAD_PUBLIC_PATH=/uploads
UPLOAD_PUBLIC_BASE_URL=https://your-site.example.com

LEGACY_IMAGE_HOSTS=qiniu.godlei.cn,javaweb-godlei.oss-cn-beijing.aliyuncs.com
REQUEST_TIMEOUT_MS=15000

# true = only scan and report
# false = download + rewrite database + validation
DRY_RUN=true

REPORT_PATH=./reports/legacy-image-migration-report.json
KEEP_SOURCE_URL_REPORT=true
